---
import Base from '../layouts/Base.astro';
---

<Base title="404 - Halaman Tidak Ditemukan | fmr.blog" description="Halaman yang Anda cari tidak ada.">
  <div class="error-container">
    <h1 class="error-code">404</h1>
    <h2 class="error-title">Koneksi Terputus</h2>
    <p class="error-msg">Waduh! Halaman yang Anda cari sepertinya tidak ada di server ini, atau sudah dipindahkan.</p>
    
    <div class="terminal-box">
      <div class="terminal-header">
        <span class="dot red"></span>
        <span class="dot yellow"></span>
        <span class="dot green"></span>
        <span class="title">ping fmr.blog</span>
      </div>
      <div class="terminal-body">
        <code>$ ping /halaman-ini
> Request timeout for icmp_seq 0
> Destination port unreachable
> 404 Not Found</code>
      </div>
    </div>
    
    <a href="/" class="btn btn-primary">Kembali ke Beranda</a>
  </div>
</Base>

<style>
  .error-container {
    text-align: center;
    margin: 4rem auto 8rem auto;
    max-width: 600px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .error-code {
    font-size: clamp(6rem, 15vw, 10rem);
    font-weight: 900;
    line-height: 1;
    margin-bottom: 0.5rem;
    background: var(--color-accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    filter: drop-shadow(0 10px 20px rgba(74, 120, 86, 0.2));
  }
  .error-title {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }
  .error-msg {
    font-size: 1.1rem;
    color: var(--color-muted);
    margin-bottom: 3rem;
  }
  
  .terminal-box {
    background: #0d1117;
    border-radius: 8px;
    border: 1px solid #30363d;
    width: 100%;
    text-align: left;
    overflow: hidden;
    margin-bottom: 3rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
  }
  .terminal-header {
    background: #161b22;
    padding: 0.5rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border-bottom: 1px solid #30363d;
  }
  .dot {
    width: 10px; height: 10px; border-radius: 50%;
  }
  .dot.red { background: #ff5f56; }
  .dot.yellow { background: #ffbd2e; }
  .dot.green { background: #27c93f; }
  .terminal-header .title {
    color: #8b949e;
    font-size: 0.8rem;
    font-family: monospace;
    margin-left: auto;
    margin-right: auto;
  }
  .terminal-body {
    padding: 1.5rem;
    color: #c9d1d9;
    font-family: monospace;
    font-size: 0.9rem;
    line-height: 1.5;
    white-space: pre-wrap;
  }
  
  .btn {
    padding: 0.8rem 2rem;
    border-radius: var(--radius-full);
    font-weight: 600;
    transition: all var(--transition-normal);
  }
  .btn-primary {
    background: var(--color-accent-gradient);
    color: #fff;
    box-shadow: 0 4px 15px var(--color-glow);
    text-decoration: none;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px var(--color-glow);
  }
</style>
