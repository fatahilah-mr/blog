---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Giscus from '../../components/Giscus.astro';
import LangBadge from '../../components/LangBadge.astro';
import { getReadingTime } from '../../utils/readingTime';
import ArrowBackIcon from '@mui/icons-material/ArrowBack';
import ShareIcon from '@mui/icons-material/Share';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await post.render();
const readingTime = getReadingTime(post.body || post.data.description);

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": post.data.pubDate.toISOString(),
  "dateModified": post.data.updatedDate ? post.data.updatedDate.toISOString() : post.data.pubDate.toISOString(),
  "image": post.data.heroImage ? new URL(post.data.heroImage, Astro.site).toString() : new URL('/uploads/Logo Web Blog.png', Astro.site).toString(),
  "author": {
    "@type": "Person",
    "name": "Fatahilah M. R.",
    "url": "https://blog.fatahmr.my.id"
  },
  "publisher": {
    "@type": "Organization",
    "name": "fmr.blog",
    "logo": {
      "@type": "ImageObject",
      "url": "https://blog.fatahmr.my.id/favicon.svg"
    }
  },
  "inLanguage": post.data.lang || "id"
};
---

<Base 
  title={post.data.title} 
  description={post.data.description}
  image={post.data.heroImage}
  lang={post.data.lang}
  type="article"
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <article class="post-container">
    <div class="top-actions">
      <a href="/blog" class="back-link" style="display:inline-flex; align-items:center; gap:0.3rem;"><ArrowBackIcon sx={{ fontSize: '1rem' }} /> Kembali ke Blog</a>
      <button id="share-btn" class="share-btn" aria-label="Bagikan artikel" style="display:inline-flex; align-items:center; gap:0.4rem;">
        <ShareIcon sx={{ fontSize: '1rem' }} />
        Bagikan
      </button>
    </div>
    <header class="post-header">
      <div class="meta">
        <span class="meta-item date">{post.data.pubDate.toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
        <span class="dot">•</span>
        <span class="meta-item">{readingTime} menit baca</span>
        <span class="dot lang-dot">•</span>
        <div class="meta-item lang-item">
          <LangBadge item={post} />
        </div>
      </div>
      <h1 class="title">{post.data.title}</h1>
      <div class="tags">
        {post.data.tags.map((tag: string) => <span class="tag">#{tag}</span>)}
      </div>
    </header>
    
    {headings && headings.length > 0 && (
      <details class="toc glass-panel" open>
        <summary class="toc-summary">
          <div class="toc-title">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="8" y1="6" x2="21" y2="6"></line>
              <line x1="8" y1="12" x2="21" y2="12"></line>
              <line x1="8" y1="18" x2="21" y2="18"></line>
              <line x1="3" y1="6" x2="3.01" y2="6"></line>
              <line x1="3" y1="12" x2="3.01" y2="12"></line>
              <line x1="3" y1="18" x2="3.01" y2="18"></line>
            </svg>
            <span>Daftar Isi</span>
          </div>
          <svg class="chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </summary>
        <div class="toc-content">
          <ul>
            {headings.map((h: any) => (
              <li class={`depth-${h.depth}`}>
                <a href={`#${h.slug}`}>{h.text}</a>
              </li>
            ))}
          </ul>
        </div>
      </details>
    )}
    
    <div class="prose">
      <Content />
    </div>
    
    {post.data.references && post.data.references.length > 0 && (
      <details class="references-accordion glass-panel">
        <summary class="references-summary">
          <div class="ref-title-box">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
              <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
            </svg>
            <span>{post.data.lang === 'en' ? 'References & Cited Sources' : 'Daftar Sumber & Referensi Dikutip'} ({post.data.references.length})</span>
          </div>
          <svg class="chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </summary>
        <ul class="references-list">
          {post.data.references.map((ref: { title: string; url?: string }) => (
            <li>
              <span class="ref-item-title">{ref.title}</span>
              {ref.url && (
                <a href={ref.url} target="_blank" rel="noopener noreferrer" class="ref-item-link">
                  {ref.url} ↗
                </a>
              )}
            </li>
          ))}
        </ul>
      </details>
    )}
    
    <hr class="divider" />
    <Giscus />
  </article>
</Base>

<style>
  .post-container {
    max-width: 750px;
    margin: 0 auto;
  }
  .top-actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }
  .back-link {
    color: var(--color-muted);
    font-weight: 500;
    transition: color var(--transition-fast), transform var(--transition-fast);
    display: inline-flex;
    align-items: center;
  }
  .back-link:hover {
    color: var(--color-accent);
    transform: translateX(-4px);
    text-decoration: none;
  }
  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--glass-bg);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    padding: 0.4rem 0.8rem;
    border-radius: var(--radius-full);
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    transition: all var(--transition-fast);
  }
  .share-btn:hover {
    background: var(--color-surface);
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .share-btn.copied {
    color: #10B981;
    border-color: #10B981;
  }
  .post-header {
    margin-bottom: 3rem;
    text-align: center;
  }
  .meta {
    color: var(--color-muted);
    font-size: 0.95rem;
    margin-bottom: 1.25rem;
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  .meta-item {
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
  }
  .dot {
    opacity: 0.45;
    user-select: none;
  }
  .lang-dot {
    display: none;
  }
  .lang-item {
    flex-basis: 100%;
    justify-content: center;
    margin-top: 0.15rem;
  }
  @media (min-width: 768px) {
    .lang-dot {
      display: inline;
    }
    .lang-item {
      flex-basis: auto;
      margin-top: 0;
    }
  }
  .lang-badge {
    background: var(--color-surface);
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-full);
    font-size: 0.8rem;
    font-weight: 600;
  }
  .title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 1.5rem;
  }
  .tags {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .tag {
    color: var(--color-accent-text);
    font-weight: 500;
    font-size: 0.9rem;
  }
  .toc {
    margin-bottom: 3rem;
    border-radius: var(--radius-lg);
    border-left: 4px solid var(--color-accent);
    overflow: hidden;
  }
  .toc-summary {
    padding: 1.25rem 1.5rem;
    font-weight: 700;
    cursor: pointer;
    outline: none;
    font-size: 1.1rem;
    color: var(--color-text);
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(0, 0, 0, 0.02);
    list-style: none; /* Hide default arrow */
    transition: background var(--transition-fast);
  }
  .toc-summary::-webkit-details-marker {
    display: none;
  }
  .toc-summary:hover {
    background: var(--color-surface-hover);
  }
  .toc-title {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .chevron {
    transition: transform var(--transition-normal);
    color: var(--color-muted);
  }
  details[open] .chevron {
    transform: rotate(180deg);
  }
  .toc-content {
    padding: 0 1.5rem 1.25rem 1.5rem;
    border-top: 1px solid var(--color-border);
    margin-top: 0.5rem;
  }
  .toc ul {
    margin-top: 1rem;
    list-style: none;
    padding-left: 0;
  }
  .toc li {
    margin-bottom: 0.6rem;
    position: relative;
  }
  .toc a {
    color: var(--color-muted);
    text-decoration: none;
    font-size: 0.95rem;
    transition: color var(--transition-fast);
    display: block;
    line-height: 1.5;
  }
  .toc a:hover {
    color: var(--color-accent);
  }
  .depth-2 { padding-left: 0.5rem; font-weight: 500; }
  .depth-3 { padding-left: 1.5rem; font-size: 0.9rem; }
  .depth-4 { padding-left: 2.5rem; font-size: 0.85rem; }
  .divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 4rem 0;
  }
</style>

<script>
  const shareBtn = document.getElementById('share-btn');
  if (shareBtn) {
    shareBtn.addEventListener('click', async () => {
      const shareData = {
        title: document.title,
        text: document.querySelector('meta[name="description"]')?.getAttribute('content') || '',
        url: window.location.href
      };

      try {
        if (navigator.share) {
          await navigator.share(shareData);
        } else {
          await navigator.clipboard.writeText(window.location.href);
          const originalText = shareBtn.innerHTML;
          shareBtn.classList.add('copied');
          shareBtn.innerHTML = `
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            Tersalin!
          `;
          setTimeout(() => {
            shareBtn.classList.remove('copied');
            shareBtn.innerHTML = originalText;
          }, 2000);
        }
      } catch (err) {
        console.error('Error sharing:', err);
      }
    });
  }
</script>
