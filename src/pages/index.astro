---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ArticleCard from '../components/ArticleCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ArrowForwardIcon from '@mui/icons-material/ArrowForward';
import EmojiEventsIcon from '@mui/icons-material/EmojiEvents';

const posts = await getCollection('blog');
const projects = await getCollection('projects');

// Sort & limit
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const recentPosts = posts.slice(0, 3);

projects.sort((a, b) => b.data.startDate.valueOf() - a.data.startDate.valueOf());
const featuredProjects = projects.filter(p => p.data.featured).slice(0, 2);
---

<Base title="fmr.blog | Fatahilah Miftahul Rahman" description="Personal blog dan proyek Fatahilah Miftahul Rahman - Juara 1 LKS IT Network System Administration, Web Development & AI Prompt Engineering Specialist">
  <section class="hero">
    <div class="badge">
      <EmojiEventsIcon sx={{ fontSize: '1rem', color: '#F59E0B', verticalAlign: 'middle', marginRight: '4px' }} /> Juara 1 LKS IT Network System Administration 2026
    </div>
    <h1 class="hero-title">
      Fatahilah <span class="text-gradient">Miftahul Rahman</span>
    </h1>
    <p class="hero-tagline">"Connecting the future, one network at a time."</p>
    <p class="hero-desc">
      Spesialis <strong>IT Network & System Administration</strong>, konfigurasi server Linux/Windows, infrastruktur jaringan Cisco & MikroTik, otomatisasi berbasis <strong>AI Prompt Engineering</strong>, serta <strong>Web Development</strong> responsif.
    </p>
    <div class="hero-actions">
      <a href="/blog" class="btn btn-primary group" style="display:inline-flex; align-items:center;">
        <span>Baca Artikel</span>
        <div class="icon-pill">
          <ArrowForwardIcon sx={{ fontSize: '1rem' }} />
        </div>
      </a>
      <a href="/projects" class="btn btn-secondary group" style="display:inline-flex; align-items:center;">
        <span>Lihat Proyek</span>
        <div class="icon-pill">
          <ArrowForwardIcon sx={{ fontSize: '1rem' }} />
        </div>
      </a>
    </div>
  </section>

  <div class="grid-container">
    <section class="recent-posts">
      <div class="section-header">
        <div>
          <span class="eyebrow-pill">ARTIKEL &amp; WAWASAN</span>
          <h2>Tulisan Terbaru</h2>
        </div>
        <a href="/blog" class="view-all group" style="display:inline-flex; align-items:center;">
          <span>Lihat Semua</span>
          <div class="icon-pill" style="width:1.5rem; height:1.5rem; margin-left:0.35rem;">
            <ArrowForwardIcon sx={{ fontSize: '0.85rem' }} />
          </div>
        </a>
      </div>
      <div class="cards-list">
        {recentPosts.map(post => <ArticleCard post={post} />)}
      </div>
    </section>

    <section class="featured-projects">
      <div class="section-header">
        <div>
          <span class="eyebrow-pill">KARYA TERBAIK</span>
          <h2>Proyek Pilihan</h2>
        </div>
        <a href="/projects" class="view-all group" style="display:inline-flex; align-items:center;">
          <span>Lihat Semua</span>
          <div class="icon-pill" style="width:1.5rem; height:1.5rem; margin-left:0.35rem;">
            <ArrowForwardIcon sx={{ fontSize: '0.85rem' }} />
          </div>
        </a>
      </div>
      <div class="cards-grid">
        {featuredProjects.map(proj => <ProjectCard proj={proj} />)}
      </div>
    </section>
  </div>

  <section class="home-teasers">
    <div class="teaser-glass glass-panel">
      <div class="teaser-col teaser-about">
        <span class="eyebrow-pill">TENTANG PENULIS</span>
        <h2>Kenali Saya Lebih Jauh</h2>
        <p>Saya Fatahilah, lulusan TKJ (SMK Patriot Pituruh 2026) &amp; Juara 1 LKS IT Network System Administration dengan minat mendalam pada jaringan IT, sistem server, otomatisasi AI, dan <strong>Web Development</strong>. Saya senang memecahkan masalah kompleks serta membangun sistem dan aplikasi web yang stabil, cepat, serta efisien.</p>
        <a href="/about" class="btn btn-secondary group" style="display:inline-flex; align-items:center;">
          <span>Baca Profil Lengkap</span>
          <div class="icon-pill">
            <ArrowForwardIcon sx={{ fontSize: '0.95rem' }} />
          </div>
        </a>
      </div>
      <div class="teaser-divider"></div>
      <div class="teaser-col teaser-contact">
        <span class="eyebrow-pill">KOLABORASI &amp; PELUANG</span>
        <h2>Tertarik Bekerja Sama?</h2>
        <p>Saya selalu terbuka untuk peluang karir, proyek freelance <strong>Web Development</strong> &amp; infrastruktur jaringan, kolaborasi industri, atau diskusi teknis seputar IT Network &amp; AI Prompt Engineering.</p>
        <a href="mailto:fatahilah.f10@gmail.com" class="btn btn-primary group" style="display:inline-flex; align-items:center;">
          <span>Hubungi Saya Sekarang</span>
          <div class="icon-pill">
            <ArrowForwardIcon sx={{ fontSize: '0.95rem' }} />
          </div>
        </a>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero {
    margin: 4rem 0 6rem 0;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .badge {
    background: var(--color-accent-muted);
    color: var(--color-accent-text);
    padding: 0.4rem 1rem;
    border-radius: var(--radius-full);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 2rem;
    border: 1px solid var(--color-accent-muted);
  }
  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    line-height: 1.1;
    letter-spacing: -0.04em;
    margin-bottom: 0.75rem;
    font-weight: 800;
  }
  .hero-tagline {
    font-size: 1.25rem;
    font-weight: 600;
    font-style: italic;
    color: var(--color-accent-text);
    margin-bottom: 1.5rem;
    letter-spacing: -0.01em;
  }
  .hero-desc {
    font-size: 1.15rem;
    color: var(--color-muted);
    max-width: 680px;
    margin-bottom: 2.5rem;
    line-height: 1.7;
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
  }
  .btn {
    padding: 0.8rem 2rem;
    border-radius: var(--radius-full);
    font-weight: 600;
    white-space: nowrap;
    word-break: keep-all;
    flex-shrink: 0;
    transition: all var(--transition-normal);
  }
  .btn-primary {
    background: var(--color-accent-gradient);
    color: #fff;
    box-shadow: 0 4px 15px var(--color-glow);
  }
  @media (hover: hover) {
    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 25px var(--color-glow);
      color: #fff;
      text-decoration: none;
    }
  }
  .btn-primary:active {
    transform: translateY(0) scale(0.96);
    box-shadow: 0 4px 15px var(--color-glow);
  }
  .btn-secondary {
    background: var(--color-surface);
    color: var(--color-text);
    border: var(--glass-border);
  }
  @media (hover: hover) {
    .btn-secondary:hover {
      background: var(--color-surface-hover);
      text-decoration: none;
    }
  }
  .btn-secondary:active {
    transform: scale(0.96);
    background: var(--color-surface);
  }
  
  .grid-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4.5rem;
  }
  @media (min-width: 768px) {
    .grid-container {
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem;
    }
  }
  
  .eyebrow-pill {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-accent-light);
    margin-bottom: 0.35rem;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 1.75rem;
  }
  .section-header h2 {
    font-size: 1.65rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin: 0;
  }
  .view-all {
    font-size: 0.92rem;
    font-weight: 600;
    transition: color var(--transition-fast);
  }
  
  .cards-list, .cards-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  
  .home-teasers {
    margin-top: 5rem;
  }
  .teaser-glass {
    padding: 2.5rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg, 16px);
  }
  .teaser-col {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .teaser-col .btn {
    white-space: nowrap;
    word-break: keep-all;
    flex-shrink: 0;
    width: max-content;
    max-width: 100%;
  }
  @media (max-width: 767px) {
    .teaser-col {
      align-items: center;
      text-align: center;
    }
  }
  .teaser-col h2 {
    font-size: 1.5rem;
    font-weight: 800;
    margin: 0;
    letter-spacing: -0.02em;
  }
  .teaser-col p {
    color: var(--color-muted);
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0 0 0.5rem 0;
  }
  .teaser-divider {
    height: 1px;
    background: var(--color-border);
    width: 100%;
  }
  @media (min-width: 768px) {
    .teaser-glass {
      flex-direction: row;
      align-items: center;
      gap: 2.5rem;
      padding: 3rem 2.5rem;
    }
    .teaser-col {
      flex: 1;
    }
    .teaser-about {
      text-align: left;
    }
    .teaser-contact {
      text-align: right;
    }
    .teaser-contact .btn {
      align-self: flex-end;
    }
    .teaser-about .btn {
      align-self: flex-start;
    }
    .teaser-divider {
      width: 1px;
      height: 140px;
    }
  }
</style>
