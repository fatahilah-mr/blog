---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ArticleCard from '../components/ArticleCard.astro';
import ProjectCard from '../components/ProjectCard.astro';

const posts = await getCollection('blog');
const projects = await getCollection('projects');

// Sort & limit
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const recentPosts = posts.slice(0, 3);

projects.sort((a, b) => b.data.startDate.valueOf() - a.data.startDate.valueOf());
const featuredProjects = projects.filter(p => p.data.featured).slice(0, 2);
---

<Base title="fmr.blog" description="Personal blog and projects of fmr.">
  <section class="hero">
    <div class="badge">Selamat datang</div>
    <h1 class="hero-title">Saya <span class="text-gradient">Fatahilah Miftahul Rahman</span>. <br/>Spesialis IT Network & AI Prompt Engineering.</h1>
    <p class="hero-desc">Menghubungkan masa depan, satu jaringan pada satu waktu. Ini adalah ruang digital saya untuk berbagi pemikiran seputar administrasi jaringan, server, dan eksplorasi teknologi AI (LLM).</p>
    <div class="hero-actions">
      <a href="/blog" class="btn btn-primary">Baca Artikel</a>
      <a href="/projects" class="btn btn-secondary">Lihat Proyek</a>
    </div>
  </section>

  <div class="grid-container">
    <section class="recent-posts">
      <div class="section-header">
        <h2>Tulisan Terbaru</h2>
        <a href="/blog" class="view-all">Lihat Semua →</a>
      </div>
      <div class="cards-list">
        {recentPosts.map(post => <ArticleCard post={post} />)}
      </div>
    </section>

    <section class="featured-projects">
      <div class="section-header">
        <h2>Proyek Pilihan</h2>
        <a href="/projects" class="view-all">Lihat Semua →</a>
      </div>
      <div class="cards-grid">
        {featuredProjects.map(proj => <ProjectCard proj={proj} />)}
      </div>
    </section>
  </div>

  <section class="about-cta">
    <div class="about-cta-content glass-panel">
      <h2>Ingin tahu lebih banyak tentang latar belakang saya?</h2>
      <p>Pelajari perjalanan karir, keahlian teknis, dan filosofi saya dalam dunia IT Network & AI.</p>
      <a href="/about" class="btn btn-primary">Baca Profil Saya</a>
    </div>
  </section>
</Base>

<style>
  .hero {
    margin: 4rem 0 6rem 0;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .badge {
    background: var(--color-accent-muted);
    color: var(--color-accent-text);
    padding: 0.4rem 1rem;
    border-radius: var(--radius-full);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 2rem;
    border: 1px solid var(--color-accent-muted);
  }
  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    line-height: 1.1;
    letter-spacing: -0.04em;
    margin-bottom: 1.5rem;
    font-weight: 800;
  }
  .hero-desc {
    font-size: 1.15rem;
    color: var(--color-muted);
    max-width: 600px;
    margin-bottom: 2.5rem;
    line-height: 1.7;
  }
  .hero-actions {
    display: flex;
    gap: 1rem;
  }
  .btn {
    padding: 0.8rem 2rem;
    border-radius: var(--radius-full);
    font-weight: 600;
    transition: all var(--transition-normal);
  }
  .btn-primary {
    background: var(--color-accent-gradient);
    color: #fff;
    box-shadow: 0 4px 15px var(--color-glow);
  }
  @media (hover: hover) {
    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 25px var(--color-glow);
      color: #fff;
      text-decoration: none;
    }
  }
  .btn-primary:active {
    transform: translateY(0) scale(0.96);
    box-shadow: 0 4px 15px var(--color-glow);
  }
  .btn-secondary {
    background: var(--color-surface);
    color: var(--color-text);
    border: var(--glass-border);
  }
  @media (hover: hover) {
    .btn-secondary:hover {
      background: var(--color-surface-hover);
      text-decoration: none;
    }
  }
  .btn-secondary:active {
    transform: scale(0.96);
    background: var(--color-surface);
  }
  
  .grid-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
  }
  @media (min-width: 768px) {
    .grid-container {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
  }
  
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1.5rem;
  }
  .section-header h2 {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }
  .view-all {
    font-size: 0.9rem;
    font-weight: 600;
  }
  
  .cards-list, .cards-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  
  .about-cta {
    margin-top: 5rem;
    text-align: center;
  }
  
  .about-cta-content {
    padding: 3rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    border: 1px solid var(--color-border);
  }
  
  .about-cta h2 {
    font-size: 1.8rem;
    margin: 0;
    font-weight: 800;
    letter-spacing: -0.02em;
  }
  
  .about-cta p {
    color: var(--color-muted);
    font-size: 1.1rem;
    max-width: 500px;
    margin-bottom: 1rem;
  }
</style>
