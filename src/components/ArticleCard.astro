---
import { getReadingTime } from '../utils/readingTime';
import LangBadge from './LangBadge.astro';
import ArrowForwardIcon from '@mui/icons-material/ArrowForward';

interface Props {
  post: any;
}
const { post } = Astro.props;
const readingTime = getReadingTime(post.body || post.data.description);
---
<a href={`/blog/${post.slug}`} class="card-link group" data-tags={post.data.tags?.join(',') || ''}>
  <div class="outer-shell">
    <article class="glass-panel card">
      <div class="meta">
        <span class="date">{post.data.pubDate.toLocaleDateString('id-ID', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
        <div style="display:flex; gap: 0.5rem; align-items:center;">
          <span>{readingTime} min read</span>
          <LangBadge item={post} />
        </div>
      </div>
      <h3 class="title">{post.data.title}</h3>
      <p class="desc">{post.data.description}</p>
      <div class="read-more">
        <span>Baca selengkapnya</span>
        <div class="icon-pill" style="width:1.6rem; height:1.6rem; margin-left:0.25rem;">
          <ArrowForwardIcon sx={{ fontSize: '0.9rem' }} />
        </div>
      </div>
    </article>
  </div>
</a>

<style>
  .card-link {
    display: block;
    text-decoration: none !important;
    color: inherit !important;
  }
  .outer-shell {
    padding: 0.35rem;
    border-radius: calc(var(--radius-md) + 0.35rem);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition: transform var(--transition-fluid), background var(--transition-fluid), border-color var(--transition-fluid);
    height: 100%;
  }
  .card-link:hover .outer-shell {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.16);
    transform: translateY(-4px);
  }
  .card {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    height: 100%;
  }
  .meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.85rem;
    color: var(--color-muted);
    font-weight: 500;
  }
  .lang-badge {
    background: var(--color-surface-hover);
    padding: 0.1rem 0.5rem;
    border-radius: 4px;
    font-size: 0.75rem;
  }
  .title {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.4;
  }
  .desc {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.95rem;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .read-more {
    margin-top: auto;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-accent-light);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: gap var(--transition-fast);
  }
  .glass-panel:hover .read-more {
    gap: 0.8rem;
    color: var(--color-accent);
  }
</style>
