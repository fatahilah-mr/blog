---
import EmailIcon from '@mui/icons-material/Email';
import LanguageIcon from '@mui/icons-material/Language';
import LinkedInIcon from '@mui/icons-material/LinkedIn';
import GitHubIcon from '@mui/icons-material/GitHub';
import RssFeedIcon from '@mui/icons-material/RssFeed';

const today = new Date();
---

<footer>
  <div class="footer-content">
    
    <div class="footer-brand">
      <h3>fmr.blog</h3>
      <p class="footer-slogan">Pusat berbagi pengetahuan, informasi, dan dokumentasi teknologi yang bermanfaat bagi banyak orang.</p>
    </div>

    <div class="footer-nav">
      <a href="/">Beranda</a>
      <a href="/blog">Blog</a>
      <a href="/projects">Proyek</a>
      <a href="/about">Tentang Saya</a>
    </div>

    <div class="footer-socials">
      <!-- Email -->
      <a href="mailto:fatahilah.f10@gmail.com" aria-label="Email" title="Email">
        <EmailIcon sx={{ fontSize: '1.25rem' }} />
      </a>
      <!-- Gerbang -->
      <a href="https://g.fatahmr.my.id" target="_blank" rel="noopener noreferrer" aria-label="Gerbang" title="Gerbang">
        <LanguageIcon sx={{ fontSize: '1.25rem' }} />
      </a>
      <!-- LinkedIn -->
      <a href="https://www.linkedin.com/in/fatahilah-miftahul-rahman" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" title="LinkedIn">
        <LinkedInIcon sx={{ fontSize: '1.25rem' }} />
      </a>
      <!-- GitHub -->
      <a href="https://github.com/fatahilah-mr" target="_blank" rel="noopener noreferrer" aria-label="GitHub" title="GitHub">
        <GitHubIcon sx={{ fontSize: '1.25rem' }} />
      </a>
      <!-- RSS -->
      <a href="/rss.xml" aria-label="RSS Feed" title="RSS Feed">
        <RssFeedIcon sx={{ fontSize: '1.25rem' }} />
      </a>
    </div>

    <div class="footer-bottom">
      <div class="footer-copy">
        &copy; {today.getFullYear()} <strong>Fatahilah Miftahul Rahman</strong>. Hak Cipta Dilindungi.
      </div>
      <div class="footer-credits">
        Dibuat dengan presisi menggunakan <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro 5</a>, <a href="https://sveltia.dev/cms/" target="_blank" rel="noopener noreferrer">Sveltia CMS</a> &amp; Vanilla CSS.
      </div>
    </div>
  </div>
</footer>

<style>
  footer {
    padding: 4em 1.5em;
    background: var(--color-surface);
    color: var(--color-muted);
    border-top: 1px solid var(--color-border);
    margin-top: auto;
  }
  .footer-content {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }
  
  .footer-brand {
    text-align: center;
  }
  .footer-brand h3 {
    color: var(--color-text);
    margin: 0 0 0.5rem 0;
    font-size: 1.5rem;
    font-weight: 700;
  }
  .footer-slogan {
    margin: 0;
    font-size: 0.95rem;
  }

  .footer-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
  }
  .footer-nav a {
    color: var(--color-text);
    font-size: 0.9rem;
    font-weight: 500;
    padding: 0.5rem 1.25rem;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    transition: all var(--transition-fast);
  }
  
  .footer-socials {
    display: flex;
    gap: 1rem;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
  }
  .footer-socials a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--color-surface);
    color: var(--color-text);
    border: 1px solid var(--color-border);
    transition: all var(--transition-fast);
  }

  @media (hover: hover) {
    .footer-nav a:hover {
      color: var(--color-accent-text);
      background: var(--color-surface-hover);
      border-color: var(--color-accent);
      text-decoration: none;
    }
    .footer-socials a:hover {
      color: var(--color-accent-text);
      background: var(--color-surface-hover);
      border-color: var(--color-accent);
      transform: translateY(-4px);
      box-shadow: 0 4px 12px var(--color-glow);
    }
  }
  
  .footer-nav a:active, .footer-socials a:active {
    transform: scale(0.95);
  }

  .footer-bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1rem;
    font-size: 0.85rem;
    text-align: center;
    border-top: 1px solid var(--color-border);
    padding-top: 2rem;
    width: 100%;
  }
  
  .footer-credits a {
    color: var(--color-accent-text);
    text-decoration: none;
    font-weight: 500;
  }
  .footer-credits a:hover {
    text-decoration: underline;
  }
</style>
