---
<button id="theme-toggle" class="theme-toggle" aria-label="Toggle theme">
  <svg class="sun-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
  <svg class="moon-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
  <svg class="spinner-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="2" x2="12" y2="6"></line><line x1="12" y1="18" x2="12" y2="22"></line><line x1="4.93" y1="4.93" x2="7.76" y2="7.76"></line><line x1="16.24" y1="16.24" x2="19.07" y2="19.07"></line><line x1="2" y1="12" x2="6" y2="12"></line><line x1="18" y1="12" x2="22" y2="12"></line><line x1="4.93" y1="19.07" x2="7.76" y2="16.24"></line><line x1="16.24" y1="7.76" x2="19.07" y2="4.93"></line></svg>
</button>

<style>
  .theme-toggle {
    background: transparent;
    border: none;
    color: var(--color-text);
    cursor: pointer;
    padding: 0.5rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background var(--transition-fast), transform var(--transition-fast);
  }
  @media (hover: hover) {
    .theme-toggle:hover {
      background: var(--color-surface-hover);
    }
  }
  .theme-toggle:active {
    transform: scale(0.9);
    background: var(--color-surface);
  }
  .sun-icon { display: none; }
  .moon-icon { display: block; }
  .spinner-icon {
    display: none;
    animation: spin 1s linear infinite;
  }
  
  @keyframes spin {
    100% { transform: rotate(360deg); }
  }
  
  :global(.theme-light) .sun-icon { display: block; }
  :global(.theme-light) .moon-icon { display: none; }
  
  /* Loading overrides */
  .theme-toggle.is-loading .spinner-icon { display: block; }
  .theme-toggle.is-loading .sun-icon, 
  .theme-toggle.is-loading .moon-icon { display: none !important; }
</style>

<script>
  const handleToggleClick = (e: Event) => {
    const btn = e.currentTarget as HTMLElement;
    
    // 1. Switch site theme instantly
    const element = document.documentElement;
    element.classList.toggle('theme-light');
    
    const isLight = element.classList.contains('theme-light');
    localStorage.setItem('theme', isLight ? 'light' : 'dark');
    
    // 2. Dispatch event for external components (Giscus) to sync themes
    document.dispatchEvent(new CustomEvent('theme-changed', { detail: isLight ? 'light' : 'dark' }));
    
    // 3. Show loading state to prevent spam and indicate background sync
    btn.classList.add('is-loading');
    btn.style.pointerEvents = 'none';
    
    setTimeout(() => {
      btn.classList.remove('is-loading');
      btn.style.pointerEvents = 'auto';
    }, 500);
  }
  
  document.getElementById('theme-toggle')?.addEventListener('click', handleToggleClick);
</script>
