{
  "$ref": "#/definitions/projects",
  "definitions": {
    "projects": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "completed",
            "archived"
          ]
        },
        "techStack": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "repoUrl": {
          "type": "string",
          "format": "uri"
        },
        "demoUrl": {
          "type": "string",
          "format": "uri"
        },
        "heroImage": {
          "type": "string"
        },
        "featured": {
          "type": "boolean",
          "default": false
        },
        "startDate": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "description",
        "status",
        "techStack",
        "startDate"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}